{
  "manifestVersion": 1,
  "id": "community-hub",
  "publisher": "Esmail-BenMoussa",
  "version": "0.1.6",
  "name": "Community Hub",
  "description": "A GitHub Discussions-like collaborative discussion platform for Azure DevOps. Create announcements, gather feedback, and build community around your projects.",
  "public": false,
  "categories": ["Azure Boards"],
  "tags": [
    "discussions",
    "community",
    "announcements",
    "collaboration",
    "feedback"
  ],
  "targets": [
    {
      "id": "Microsoft.VisualStudio.Services"
    }
  ],
  "screenshots": [],
  "contributions": [
    {
      "id": "community-hub-group",
      "type": "ms.vss-web.hub-group",
      "targets": ["ms.vss-web.project-hub-groups-collection"],
      "properties": {
        "name": "Community",
        "icon": "asset://public/icons/community-icon.png",
        "order": 50
      }
    },
    {
      "id": "community-hub",
      "type": "ms.vss-web.hub",
      "targets": [".community-hub-group"],
      "properties": {
        "name": "Discussions",
        "icon": "asset://public/icons/discussions-icon.png",
        "order": 1,
        "uri": "dist/index.html"
      }
    },
    {
      "id": "community-hub-org",
      "type": "ms.vss-web.hub",
      "targets": ["ms.vss-web.collection-admin-hub-group"],
      "properties": {
        "name": "Community Hub",
        "icon": "asset://public/icons/community-icon.png",
        "order": 100,
        "uri": "dist/index.html?view=org"
      }
    }
  ],
  "scopes": ["vso.work_write", "vso.project", "vso.profile"],
  "files": [
    {
      "path": "dist",
      "addressable": true
    },
    {
      "path": "public",
      "addressable": true
    }
  ]
}
