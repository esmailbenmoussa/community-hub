{
  "manifestVersion": 1,
  "id": "community-hub",
  "publisher": "Repryl",
  "version": "0.2.12",
  "name": "Community Hub",
  "description": "Community Hub is the home for team conversations in Azure DevOps. Ask questions, share announcements, upvote ideas, and comment—right next to your work. Enable productive collaboration.",
  "public": false,
  "categories": ["Azure Boards"],
  "tags": [
    "discussions",
    "community",
    "announcements",
    "collaboration",
    "feedback",
    "communication",
    "team",
    "comments",
    "voting",
    "markdown",
    "labels",
    "forum",
    "Q&A",
    "knowledge-sharing",
    "pinning"
  ],
  "content": {
    "details": {
      "path": "README.md"
    }
  },
  "targets": [
    {
      "id": "Microsoft.VisualStudio.Services"
    }
  ],
  "screenshots": [],
  "icons": {
    "default": "public/icons/community-hub.png"
  },
  "contributions": [
    {
      "id": "community-hub-group",
      "type": "ms.vss-web.hub-group",
      "targets": ["ms.vss-web.project-hub-groups-collection"],
      "properties": {
        "name": "Community",
        "order": 50,
        "uri": "dist/index.html",
        "icon": {
          "light": "public/icons/light-icon.png",
          "dark": "public/icons/dark-icon.png"
        }
      }
    },
    {
      "id": "community-hub",
      "type": "ms.vss-web.hub",
      "targets": [".community-hub-group"],
      "properties": {
        "name": "Discussions",
        "icon": {
          "light": "public/icons/light-icon.png",
          "dark": "public/icons/dark-icon.png"
        },
        "order": 1,
        "uri": "dist/index.html"
      }
    },
    {
      "id": "community-hub-org",
      "type": "ms.vss-web.hub",
      "targets": ["ms.vss-web.collection-admin-hub-group"],
      "properties": {
        "name": "Community Hub",
        "icon": {
          "light": "public/icons/light-icon.png",
          "dark": "public/icons/dark-icon.png"
        },
        "order": 100,
        "uri": "dist/index.html?view=org"
      }
    }
  ],
  "scopes": ["vso.work_write", "vso.project", "vso.profile"],
  "files": [
    {
      "path": "dist",
      "addressable": true
    },
    {
      "path": "public",
      "addressable": true
    }
  ]
}
